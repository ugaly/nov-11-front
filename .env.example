# Copy to `.env.local` (never commit secrets).

# Spring Boot API (see server.port in application.yml). No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:9092

# SMTP — manual form email (Gmail: use App Password, not account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-email@gmail.com
